<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Core NFC: read NDEF (the NTAG424 SDM URL). -->
	<key>com.apple.developer.nfc.readersession.formats</key>
	<array>
		<string>NDEF</string>
	</array>

	<!-- Push Notifications. Set to "production" for App Store / TestFlight builds.
	     Requires the Push Notifications capability on the App ID. -->
	<key>aps-environment</key>
	<string>development</string>

	<!-- Associated domains for App Clip default experience + universal links.
	     Requires the matching apple-app-site-association on the domain. -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>appclips:app.message.sentry.red</string>
		<string>applinks:app.message.sentry.red</string>
	</array>

	<!-- Shared container for App Clip ↔ full app hand-off (non-sensitive flags). -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.red.sentry.app.SENTRY-Messenger</string>
	</array>

	<!-- Shared Keychain group: lets the Notification Service Extension read the
	     push-preview private key the app stores (to decrypt notification previews). -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)red.sentry.shared</string>
	</array>
</dict>
</plist>
