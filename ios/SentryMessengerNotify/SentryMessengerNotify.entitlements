<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Shared Keychain group: read the push-preview private key the main app
	     stored, to decrypt notification previews. Must match the app's group. -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)red.sentry.shared</string>
	</array>
</dict>
</plist>
